# Database
# Quote values that contain & or $ when using: set -a && source .env && set +a
DATABASE_URL='postgres://eukov:eukov_secret@localhost:5432/eukov?sslmode=disable'

# Backend
BACKEND_PORT=8080
UPLOAD_BASE_PATH=./uploads
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=local-dev-jwt-secret-key-32chars-minimum!
SUPER_ADMIN_EMAIL=superadmin@eukov.local
# Must match the password used when the server first bootstrapped super admin.
SUPER_ADMIN_PASSWORD=SuperAdmin123!

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Google Drive import (Cloud button in draft editor)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable: Google Picker API + Google Drive API
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
# Optional: Google Cloud project number (improves Drive picker reliability)
NEXT_PUBLIC_GOOGLE_APP_ID=

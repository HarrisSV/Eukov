# Database
# Quote values that contain & or $ when using: set -a && source .env && set +a
DATABASE_URL='postgres://eukov:eukov_secret@localhost:5432/eukov?sslmode=disable'

# Backend
BACKEND_PORT=8080
UPLOAD_BASE_PATH=./uploads
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=local-dev-jwt-secret-key-32chars-minimum!
SUPER_ADMIN_EMAIL=superadmin@eukov.local
# Must match the password used when the server first bootstrapped super admin.
SUPER_ADMIN_PASSWORD=SuperAdmin123!

# TipTap Pages Pro (Word-like pagination — optional)
# Get your token: https://cloud.tiptap.dev → My features → Pro Extensions
# Then: cd frontend && TIPTAP_PRO_TOKEN=your-token npm run tiptap:pro
TIPTAP_PRO_TOKEN=
# NEXT_PUBLIC_USE_TIPTAP_PAGES=true


# Hugging Face / Qwen 2.5 7B (AI recommendations, proofread, summaries)
# Create a token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=
# Optional overrides:
# HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
# HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models/
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable: Google Picker API + Google Drive API
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
# Optional: Google Cloud project number (improves Drive picker reliability)
NEXT_PUBLIC_GOOGLE_APP_ID=

# Database
# Quote values that contain & or $ when using: set -a && source .env && set +a
DATABASE_URL='postgres://eukov:eukov_secret@localhost:5432/eukov?sslmode=disable'

# Backend
BACKEND_PORT=8080
UPLOAD_BASE_PATH=./uploads
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=local-dev-jwt-secret-key-32chars-minimum!
SUPER_ADMIN_EMAIL=superadmin@eukov.local
# Must match the password used when the server first bootstrapped super admin.
SUPER_ADMIN_PASSWORD=SuperAdmin123!

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
